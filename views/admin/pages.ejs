<%- include('_header') %>

<h1>Site Pages</h1>
<p style="color: var(--text-dim); margin: 0.25rem 0 1.5rem; font-size: 0.9rem;">All public pages currently live on the site.</p>

<style>
    .pages-table { width: 100%; border-collapse: collapse; }
    .pages-table th {
        text-align: left;
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-dim);
        padding: 0.6rem 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .pages-table td {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        font-size: 0.9rem;
    }
    .pages-table tr:hover td { background: rgba(255,255,255,0.02); }
    .page-path {
        font-family: 'Space Mono', monospace;
        color: var(--amber);
        font-size: 0.85rem;
    }
    .page-path a { color: var(--amber); text-decoration: none; }
    .page-path a:hover { text-decoration: underline; }
    .page-type {
        display: inline-block;
        font-size: 0.7rem;
        font-family: 'Space Mono', monospace;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 0.2rem 0.5rem;
        border-radius: 3px;
        background: rgba(255,255,255,0.06);
        color: var(--text-dim);
    }
    .page-type.main { background: rgba(212,148,58,0.15); color: var(--amber); }
    .page-type.seo { background: rgba(74,222,128,0.12); color: #4ade80; }
    .page-type.feature { background: rgba(96,165,250,0.12); color: #60a5fa; }
    .page-type.legal { background: rgba(255,255,255,0.06); color: var(--text-dim); }
    .page-note { font-size: 0.8rem; color: var(--text-dim); }
</style>

<div style="background: var(--card-bg); border-radius: 6px; overflow: hidden;">
    <table class="pages-table">
        <thead>
            <tr>
                <th>Page</th>
                <th>Path</th>
                <th>Type</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
            <% pages.forEach(function(p) { %>
                <tr>
                    <td><%= p.name %></td>
                    <td class="page-path"><a href="<%= p.path %>" target="_blank"><%= p.path %></a></td>
                    <td><span class="page-type <%= p.typeClass %>"><%= p.type %></span></td>
                    <td class="page-note"><%= p.note %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</div>

<p style="color: var(--text-dim); font-size: 0.8rem; margin-top: 1.5rem;"><%= pages.length %> pages total</p>

<%- include('_footer') %>
