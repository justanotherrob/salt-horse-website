<%- include('_header') %>

<h1>Redeem Gift Card</h1>

<style>
    .redeem-search form {
        display: flex;
        gap: 0.75rem;
        max-width: 500px;
        margin-bottom: 2rem;
    }
    .redeem-search input {
        flex: 1;
        font-size: 1.1rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }
    .redeem-search .btn {
        white-space: nowrap;
        padding: 0.75rem 2rem;
    }

    .redeem-card {
        background: var(--bg-light);
        border: 1px solid var(--cream-faint);
        border-radius: 6px;
        padding: 2rem;
        max-width: 500px;
    }

    .redeem-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 0.75rem;
    }
    .redeem-card-code {
        font-family: 'Space Mono', monospace;
        font-size: 1.3rem;
        letter-spacing: 0.1em;
        color: var(--amber);
        background: rgba(212, 148, 58, 0.1);
        padding: 0.4rem 0.8rem;
        border-radius: 4px;
    }

    .redeem-balance {
        text-align: center;
        padding: 1.5rem 0;
        margin-bottom: 1.5rem;
        border-top: 1px solid var(--cream-faint);
        border-bottom: 1px solid var(--cream-faint);
    }
    .redeem-balance-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--cream-dim);
        margin-bottom: 0.25rem;
    }
    .redeem-balance-amount {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--amber);
        line-height: 1.2;
    }

    .redeem-meta {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        gap: 1rem;
        flex-wrap: wrap;
    }
    .redeem-meta-item {
        font-size: 0.85rem;
    }
    .redeem-meta-label {
        color: var(--cream-dim);
    }
    .redeem-meta-value {
        font-weight: 600;
    }

    /* Redeem actions — stacked for clarity on mobile */
    .redeem-actions {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .redeem-action-primary .btn-fill {
        width: 100%;
        padding: 1rem;
        font-size: 0.85rem;
        text-align: center;
    }
    .redeem-action-divider {
        text-align: center;
        font-size: 0.75rem;
        color: var(--cream-dim);
        text-transform: uppercase;
        letter-spacing: 0.15em;
    }
    .redeem-custom-row {
        display: flex;
        gap: 0.75rem;
    }
    .redeem-custom-row input {
        flex: 1;
        font-size: 1rem;
    }
    .redeem-custom-row .btn {
        white-space: nowrap;
        padding: 0.75rem 1.5rem;
    }

    /* Transaction history */
    .tx-history {
        max-width: 500px;
        margin-top: 2rem;
    }
    .tx-history h3 {
        margin-bottom: 0.75rem;
    }
    .tx-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--cream-faint);
        gap: 1rem;
    }
    .tx-item:last-child {
        border-bottom: none;
    }
    .tx-info {
        flex: 1;
    }
    .tx-type {
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: capitalize;
    }
    .tx-date {
        font-size: 0.75rem;
        color: var(--cream-dim);
    }
    .tx-note {
        font-size: 0.75rem;
        color: var(--cream-dim);
        font-style: italic;
    }
    .tx-amount {
        font-weight: 700;
        font-size: 1rem;
        white-space: nowrap;
    }
    .tx-amount.purchase { color: var(--success); }
    .tx-amount.redemption { color: var(--amber); }
    .tx-amount.import { color: var(--info); }

    @media (max-width: 500px) {
        .redeem-card {
            padding: 1.25rem;
        }
        .redeem-balance-amount {
            font-size: 2rem;
        }
        .redeem-custom-row {
            flex-direction: column;
        }
        .redeem-custom-row .btn {
            width: 100%;
            text-align: center;
        }
    }
</style>

<div class="redeem-search">
    <form method="GET">
        <input type="text" name="code" placeholder="Enter gift card code" value="<%= code %>" required>
        <button type="submit" class="btn">Search</button>
    </form>
</div>

<% if (card) { %>
    <div class="redeem-card">
        <div class="redeem-card-header">
            <span class="redeem-card-code"><%= card.code %></span>
            <span class="badge <%= card.status %>"><%= card.status %></span>
        </div>

        <div class="redeem-balance">
            <div class="redeem-balance-label">Balance</div>
            <div class="redeem-balance-amount">£<%= (card.balance / 100).toFixed(2) %></div>
        </div>

        <div class="redeem-meta">
            <div class="redeem-meta-item">
                <span class="redeem-meta-label">Expires: </span>
                <span class="redeem-meta-value"><%= card.expires_at ? new Date(card.expires_at).toLocaleDateString('en-GB') : '—' %></span>
            </div>
            <div class="redeem-meta-item">
                <span class="redeem-meta-label">Original: </span>
                <span class="redeem-meta-value">£<%= (card.initial_amount / 100).toFixed(2) %></span>
            </div>
        </div>

        <% if (card.status === 'active' || (card.status === 'expired' && card.balance > 0)) { %>
            <% if (card.status === 'expired') { %>
                <div style="background: rgba(231, 76, 60, 0.15); border: 1px solid rgba(231, 76, 60, 0.4); border-radius: 4px; padding: 0.75rem 1rem; margin-bottom: 1.25rem; font-size: 0.85rem; color: #e74c3c;">
                    This gift card has expired but still has a remaining balance.
                </div>
            <% } %>
            <div class="redeem-actions">
                <div class="redeem-action-primary">
                    <button class="btn btn-fill" onclick="redeemAll('<%= card.code %>')">Redeem Full Balance — £<%= (card.balance / 100).toFixed(2) %></button>
                </div>
                <div class="redeem-action-divider">or enter a custom amount</div>
                <div class="redeem-custom-row">
                    <input type="number" id="customAmount" placeholder="£ amount" min="0.01" max="<%= (card.balance / 100).toFixed(2) %>" step="0.01">
                    <button class="btn" onclick="redeemCustom('<%= card.code %>')">Redeem</button>
                </div>
            </div>
        <% } %>
    </div>

    <% if (transactions && transactions.length > 0) { %>
        <div class="tx-history">
            <h3>Transaction History</h3>
            <% transactions.forEach(function(tx) { %>
                <div class="tx-item">
                    <div class="tx-info">
                        <div class="tx-type"><%= tx.type %></div>
                        <div class="tx-date"><%= new Date(tx.created_at).toLocaleDateString('en-GB') %></div>
                        <% if (tx.note) { %><div class="tx-note"><%= tx.note %></div><% } %>
                    </div>
                    <div class="tx-amount <%= tx.type %>">
                        <%= tx.type === 'purchase' || tx.type === 'import' ? '+' : '−' %>£<%= (tx.amount / 100).toFixed(2) %>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>

<% } else if (code) { %>
    <div class="alert alert-warning">
        Gift card not found
    </div>
<% } else { %>
    <div class="alert alert-info">
        Enter a gift card code to get started
    </div>
<% } %>

<script>
const isExpired = <%= card && card.status === 'expired' ? 'true' : 'false' %>;

function redeemAll(code) {
    const msg = isExpired
        ? 'This gift card has expired. Are you sure you want to redeem the full balance of £<%= card ? (card.balance / 100).toFixed(2) : '0.00' %>?'
        : 'Redeem the full balance of £<%= card ? (card.balance / 100).toFixed(2) : '0.00' %>?';
    if (confirm(msg)) {
        fetch('/api/gift-cards/' + code + '/redeem', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ amount: <%= card ? card.balance : 0 %> })
        })
        .then(res => res.json())
        .then(data => {
            if (data.error) { alert('Error: ' + data.error); return; }
            alert('Done! Card fully redeemed.');
            location.reload();
        })
        .catch(err => alert('Error: ' + err.message));
    }
}

function redeemCustom(code) {
    const pounds = parseFloat(document.getElementById('customAmount').value);
    if (!pounds || pounds <= 0) {
        alert('Enter a valid amount');
        return;
    }
    const pence = Math.round(pounds * 100);

    const msg = isExpired
        ? 'This gift card has expired. Are you sure you want to redeem £' + pounds.toFixed(2) + '?'
        : 'Redeem £' + pounds.toFixed(2) + ' from this card?';
    if (confirm(msg)) {
        fetch('/api/gift-cards/' + code + '/redeem', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ amount: pence })
        })
        .then(res => res.json())
        .then(data => {
            if (data.error) { alert('Error: ' + data.error); return; }
            alert('Redeemed £' + pounds.toFixed(2) + '. Remaining balance: ' + data.balanceFormatted);
            location.reload();
        })
        .catch(err => alert('Error: ' + err.message));
    }
}
</script>

<%- include('_footer') %>
