PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Database
DATABASE_PATH=./db/salthorse.db

# Sessions
SESSION_SECRET=change-this-to-a-random-64-char-string

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
